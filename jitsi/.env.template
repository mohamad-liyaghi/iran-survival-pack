# Jitsi Meet Docker Configuration
# Placeholders (__XXX__) are replaced by setup.sh

CONFIG=__CONFIG__
HTTP_PORT=8000
HTTPS_PORT=8443
TZ=Asia/Tehran

PUBLIC_URL=__PUBLIC_URL__

# ── JVB (Video Bridge) — CRITICAL for audio/video ──
# JVB must know the server's public IP to send correct ICE candidates
JVB_ADVERTISE_IPS=__SERVER_IP__
DOCKER_HOST_ADDRESS=__SERVER_IP__

# Colibri WebSocket (JVB <-> browser bridge communication)
JVB_WS_DOMAIN=__DOMAIN__
JVB_WS_SERVER_ID=default-id
ENABLE_COLIBRI_WEBSOCKET=1
COLIBRI_WEBSOCKET_PORT=8080

# XMPP WebSocket
ENABLE_XMPP_WEBSOCKET=1

# STUN servers for ICE candidate gathering (must be reachable from Iran)
JVB_STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302,stun2.l.google.com:19302
JVB_PORT=10000

# P2P (direct connection for 2-person calls)
ENABLE_P2P=true
P2P_STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302

# SSL is terminated at the host Nginx, not inside the container
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0
ENABLE_HSTS=0

# Jitsi image tag
JITSI_IMAGE_VERSION=stable
RESTART_POLICY=unless-stopped

# Passwords — filled by gen-passwords.sh
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
JIGASI_XMPP_PASSWORD=
JIGASI_TRANSCRIBER_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
