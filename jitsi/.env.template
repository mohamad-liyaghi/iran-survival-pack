# Jitsi Meet Docker Configuration
# Placeholders (__XXX__) are replaced by setup.sh

CONFIG=__CONFIG__
HTTP_PORT=8000
HTTPS_PORT=8443
TZ=Asia/Tehran

PUBLIC_URL=__PUBLIC_URL__

# Docker host IP — needed so JVB advertises the correct address
JVB_ADVERTISE_IPS=__SERVER_IP__

# SSL is terminated at the host Nginx, not inside the container
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0

# WebSocket transports (required for modern Jitsi)
ENABLE_COLIBRI_WEBSOCKET=1
ENABLE_XMPP_WEBSOCKET=1

# Jitsi image tag
JITSI_IMAGE_VERSION=stable
RESTART_POLICY=unless-stopped

# Passwords — filled by gen-passwords.sh
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
JIGASI_XMPP_PASSWORD=
JIGASI_TRANSCRIBER_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
